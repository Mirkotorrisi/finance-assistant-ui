# ─────────────────────────────────────────────────────────────────────────────
# Finance Assistant UI – Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Finance Assistant API backend (finance-assistant-api).
# Used by all service modules in lib/services/ to reach the backend REST APIs.
# In development: http://localhost:8080
# NEXT_PUBLIC_ prefix makes it available in the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# (Server-side only) Same base URL used in Next.js API routes (e.g. tools).
API_BASE_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# Generative UI – Chat / Plan endpoint
# ─────────────────────────────────────────────────────────────────────────────

# Option A – Real backend chat/plan endpoint.
# When set, the /api/ai/chat route forwards requests here.
# The endpoint must accept POST { messages } and return:
#   { text: string, plan?: { text: string, components: UIPlanComponent[] } }
# Leave empty to fall back to Option B or C below.
CHAT_PLAN_URL=

# Option B – Mock plan generator (local dev / demo mode).
# When set to "true", the /api/ai/chat route generates a UI plan from the
# user's message using keyword matching – no OpenAI key required.
# Useful for testing UI components without a backend chat endpoint.
USE_MOCK_PLAN=true

# Option C – OpenAI fallback.
# When CHAT_PLAN_URL is empty and USE_MOCK_PLAN != true, the route uses OpenAI
# with real backend tool definitions to build the UI plan.
OPENAI_API_KEY=
