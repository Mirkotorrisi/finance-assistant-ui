# ─────────────────────────────────────────────────────────────────────────────
# Finance Assistant UI – Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Finance Assistant API backend (finance-assistant-api).
# Used by all service modules in lib/services/ to reach the backend REST APIs.
# In development: http://localhost:8080
# NEXT_PUBLIC_ prefix makes it available in the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# (Server-side only) Same base URL used in Next.js API routes (e.g. tools).
API_BASE_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# LLM Finance Assistant – Chat endpoint
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the LLM Finance Assistant backend (llm-finance-assistant).
# The UI calls POST {NEXT_PUBLIC_LLM_API_BASE_URL}/chat directly from the browser.
# In development: http://localhost:8000
# NEXT_PUBLIC_ prefix makes it available in the browser.
NEXT_PUBLIC_LLM_API_BASE_URL=http://localhost:8000
